# Database settings
DATABASE_URL=postgresql://postgres:***@localhost:5432/novelwiki
# DB_SUPERUSER_URL is used to create the database if it doesn't exist
DB_SUPERUSER_URL=postgresql://postgres:***@localhost:5432/postgres

# OpenRouter unified settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/epick/novelwiki
OPENROUTER_TITLE="Spoiler-Aware Webnovel Wiki"

# LLM Models
MODEL_FLASH=deepseek/deepseek-chat
MODEL_PRO=deepseek/deepseek-chat

# Embedding Model
EMBED_MODEL=openai/text-embedding-3-small
EMBED_DIM=1024

# Rerank Model
RERANK_MODEL=cohere/rerank-4-fast

# Retrieval params
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP=80
RRF_K=60
RETRIEVE_K=50
RERANK_TOP_N=8
MAX_ITERATIONS=5
BM25_INDEX_PATH=./data/bm25_index

# Scraper settings
SCRAPER_BASE_URL=https://fenrirealm.com
SCRAPER_CONCURRENCY=1
SCRAPER_DELAY=1.0
