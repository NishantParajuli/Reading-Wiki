# Database settings
DATABASE_URL=postgresql://postgres:***@localhost:5432/novelwiki
# DB_SUPERUSER_URL is used to create the database if it doesn't exist
DB_SUPERUSER_URL=postgresql://postgres:***@localhost:5432/postgres

# OpenRouter unified settings
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/epick/novelwiki
OPENROUTER_TITLE="Spoiler-Aware Webnovel Wiki"

# LLM Models — "Flash reads, Pro thinks". Set these to two DISTINCT models
# (a cheap reader/distiller + a stronger planner/synthesizer) to realize the
# cost/quality split. They may be the same model if you prefer.
MODEL_FLASH=deepseek/deepseek-chat
MODEL_PRO=deepseek/deepseek-chat

# Embedding Model. EMBED_DIM MUST match the model's output dimension; it is
# interpolated into the pgvector columns at schema-init time. Changing it later
# requires re-running the schema migration and re-embedding.
EMBED_MODEL=cohere/embed-english-v3.0
EMBED_DIM=1024
# Set true for models that accept a requested output size (e.g. OpenAI
# text-embedding-3-*); leave false for fixed-dimension models (e.g. Cohere v3).
EMBED_REQUEST_DIMENSIONS=false

# Rerank Model
RERANK_MODEL=cohere/rerank-4-fast

# Retrieval params
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP=80
RRF_K=60
RETRIEVE_K=50
RERANK_TOP_N=8
MAX_ITERATIONS=5
BM25_INDEX_PATH=./data/bm25_index

# Extraction accuracy knobs
# Chars of each chapter fed into the running "story-so-far" summary. Keep large
# enough to cover a whole chapter (~44k chars for 8k words) so late-chapter events
# carry forward; lower only to trade continuity for cost.
SUMMARY_INPUT_MAX_CHARS=48000
# Entity-linking thresholds (pg_trgm + cosine, 0..1). A single fuzzy candidate is
# auto-accepted only at/above FUZZY_AUTO_ACCEPT; gray-zone matches go to the LLM
# disambiguator so similarly-named distinct entities don't silently merge.
FUZZY_MATCH_THRESHOLD=0.35
FUZZY_AUTO_ACCEPT=0.6
SEMANTIC_MATCH_THRESHOLD=0.85
# Run a second LLM pass per chapter to catch missed facts/relationships/events and
# identity reveals. One extra call per chapter; set false to save cost.
EXTRACTION_VERIFY=true

# Scraper settings
# SCRAPER_ADAPTER selects a site adapter: "fenrirealm" (built-in) or "generic".
# The "generic" adapter reads the CSS selectors below so a new site needs no code.
SCRAPER_ADAPTER=fenrirealm
SCRAPER_BASE_URL=https://fenrirealm.com
SCRAPER_DELAY=1.0
SCRAPER_TITLE_SELECTOR=h1
SCRAPER_CONTENT_SELECTOR=article
SCRAPER_NEXT_SELECTOR=a[rel=next]
