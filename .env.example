# Database settings
# Under docker compose (off host networking) use host `host.docker.internal` instead of `localhost`
# so the container reaches PostgreSQL on the host, e.g. postgresql://postgres:***@host.docker.internal:5432/novelwiki
DATABASE_URL=postgresql://postgres:***@localhost:5432/novelwiki
DB_SUPERUSER_URL=postgresql://postgres:***@localhost:5432/postgres

# OpenRouter unified settings
OPENROUTER_API_KEY=***
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://github.com/epick/novelwiki
OPENROUTER_TITLE="Spoiler-Aware Webnovel Wiki"

# LLM Models
MODEL_FLASH=deepseek/deepseek-v4-flash
MODEL_PRO=deepseek/deepseek-v4-pro

# Embedding Model
EMBED_MODEL=perplexity/pplx-embed-v1-0.6b
EMBED_DIM=1024

# Rerank Model
RERANK_MODEL=cohere/rerank-4-fast

# Retrieval params
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP=80
RRF_K=60
RETRIEVE_K=50
RERANK_TOP_N=8
MAX_ITERATIONS=5
BM25_INDEX_PATH=./data/bm25_index
# Run BM25 tokenize/index/search off the event loop so heavy lexical search can't stall requests.
BM25_THREAD_OFFLOAD=true

# Read-side AI cost controls (denial-of-wallet guards for uncached /ask + entity-profile synthesis).
# Cache hits are free; only uncached AI reads are gated. See novelwiki/ai_limits.py.
ASK_MAX_QUERY_CHARS=1000
ASK_MAX_UNIQUE_PER_USER_HOUR=30
ASK_MAX_CONCURRENT_PER_USER=2
ASK_CONCURRENCY_TTL_SECONDS=180
ASK_REQUIRE_VERIFIED=true
ENTITY_PROFILE_SYNTH_REQUIRE_VERIFIED=true
ASK_TOOL_MAX_K=100
ASK_TOOL_MAX_TOP_N=20
ASK_TOOL_MAX_RERANK_HITS=100
ASK_TOOL_MAX_QUERY_CHARS=2000
ASK_MAX_TOOL_CALLS_PER_ITER=4

# Scraper settings
SCRAPER_BASE_URL=https://fenrirealm.com
SCRAPER_CONCURRENCY=1
SCRAPER_DELAY=1.0
SCRAPER_TIMEOUT_SECONDS=30.0
SCRAPER_MAX_RESPONSE_MB=8
SCRAPER_REQUIRE_SAME_HOST=true
SCRAPER_ALLOWED_HOST_OVERRIDES=


EXTRACTION_VERIFY=false
FUZZY_MATCH_THRESHOLD=0.35
FUZZY_AUTO_ACCEPT=0.6
SEMANTIC_MATCH_THRESHOLD=0.85

SUMMARY_INPUT_MAX_CHARS=48000

# ── File import (EPUB/PDF ingestion) ──
IMPORT_DIR=./data/imports
IMPORT_INCOMING_DIR=./data/imports/incoming
ASSET_DIR=./data/assets
MAX_UPLOAD_MB=50
UPLOAD_CHUNK_MAX_MB=16              # max size of one resumable-upload chunk
UPLOAD_CHUNKED_THRESHOLD_MB=40     # client switches to chunked upload above this
IMPORT_AUTO_BUILD_CODEX=false

# Text segmentation/cleanup LLM (OpenRouter)
SEGMENT_MODEL=deepseek/deepseek-v4-pro

# Vision provider — Gemini (OpenAI-compatible endpoint), used for scanned-PDF OCR escalation
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_DAILY_BUDGET=2000
GEMINI_RPM=10
GEMINI_PAGES_PER_REQUEST=3

# OCR sidecar (PaddleOCR PP-StructureV3) — separate GPU deploy on localhost
OCR_SIDECAR_URL=http://localhost:8077
OCR_ENABLED=true
OCR_CONFIDENCE_ESCALATE=0.80

# TTS sidecar (OmniVoice narration) — separate GPU deploy on localhost
TTS_SIDECAR_URL=http://localhost:8078

# ── Sidecar service auth (OCR + TTS) ──
# Shared token the web app sends to the GPU sidecars; each sidecar REQUIRES it when set, so a
# reachable /ocr, /synthesize, or /narrate can only be driven by the web app. Set a long random
# value in prod. Under docker compose, the SAME value is passed to the sidecars automatically.
# Per-service overrides (OCR_SIDECAR_TOKEN / TTS_SIDECAR_TOKEN) win over the shared one.
SIDECAR_AUTH_TOKEN=
# OCR_SIDECAR_TOKEN=
# TTS_SIDECAR_TOKEN=

# ── Multi-user / auth ──
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE=tg_session
CSRF_COOKIE=tg_csrf
SESSION_TTL_DAYS=30
AUTH_LOGIN_IP_LIMIT=10
AUTH_LOGIN_ACCOUNT_LIMIT=5
AUTH_LOGIN_WINDOW_SECONDS=600
AUTH_REGISTER_IP_LIMIT=5
AUTH_REGISTER_WINDOW_SECONDS=3600
AUTH_RESET_REQUEST_IP_LIMIT=5
AUTH_RESET_REQUEST_EMAIL_LIMIT=3
AUTH_RESET_REQUEST_WINDOW_SECONDS=3600
AUTH_RESET_SUBMIT_IP_LIMIT=10
AUTH_RESET_SUBMIT_TOKEN_LIMIT=5
AUTH_RESET_SUBMIT_WINDOW_SECONDS=3600
# Comma-separated; include your tunnel domain in prod, e.g. https://read.example.com
ALLOWED_ORIGINS=http://localhost:8001,http://localhost:8000
COOKIE_SECURE=true
PUBLIC_BASE_URL=http://localhost:8001

# First admin (bootstrapped by `python -m novelwiki.db.migrate_multiuser`).
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=
ADMIN_USERNAME=admin
# Set true only after pg_dump + test restore, or use the migration CLI prompt.
MULTIUSER_MIGRATION_BACKUP_CONFIRMED=false

# Transactional email (leave SMTP_HOST blank to log links instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Tideglass <no-reply@tideglass.local>
SMTP_STARTTLS=true

# OAuth providers (leave blank to hide). Redirect URI:
#   {PUBLIC_BASE_URL}/api/auth/oauth/{google|discord}/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Monthly per-user spend quotas (admin can override per user)
DEFAULT_QUOTA_TRANSLATED_CHAPTERS=1000
DEFAULT_QUOTA_OCR_PAGES=3000
DEFAULT_QUOTA_CODEX_BUILDS=20
