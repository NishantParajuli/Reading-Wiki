{
  "input_manifest_schema": {
    "$defs": {
      "ArtifactRef": {
        "additionalProperties": false,
        "properties": {
          "bytes": {
            "minimum": 0,
            "title": "Bytes",
            "type": "integer"
          },
          "media_type": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Media Type",
            "type": "string"
          },
          "path": {
            "maxLength": 240,
            "minLength": 1,
            "title": "Path",
            "type": "string"
          },
          "role": {
            "maxLength": 80,
            "minLength": 1,
            "title": "Role",
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "title": "Sha256",
            "type": "string"
          }
        },
        "required": [
          "path",
          "sha256",
          "bytes",
          "media_type",
          "role"
        ],
        "title": "ArtifactRef",
        "type": "object"
      }
    },
    "additionalProperties": false,
    "properties": {
      "chapter_ceiling": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "default": null,
        "title": "Chapter Ceiling"
      },
      "created_at": {
        "format": "date-time",
        "title": "Created At",
        "type": "string"
      },
      "inputs": {
        "items": {
          "$ref": "#/$defs/ArtifactRef"
        },
        "title": "Inputs",
        "type": "array"
      },
      "job_id": {
        "title": "Job Id",
        "type": "integer"
      },
      "limits": {
        "additionalProperties": true,
        "title": "Limits",
        "type": "object"
      },
      "model": {
        "title": "Model",
        "type": "string"
      },
      "novel_ref": {
        "title": "Novel Ref",
        "type": "string"
      },
      "output_dir": {
        "const": "../output",
        "default": "../output",
        "title": "Output Dir",
        "type": "string"
      },
      "plugin_version": {
        "title": "Plugin Version",
        "type": "string"
      },
      "run_id": {
        "title": "Run Id",
        "type": "string"
      },
      "schema_version": {
        "const": "1.0",
        "default": "1.0",
        "title": "Schema Version",
        "type": "string"
      },
      "workload": {
        "title": "Workload",
        "type": "string"
      }
    },
    "required": [
      "run_id",
      "job_id",
      "workload",
      "plugin_version",
      "model",
      "novel_ref",
      "inputs",
      "created_at"
    ],
    "title": "InputManifest",
    "type": "object"
  },
  "output_manifest_schema": {
    "$defs": {
      "ArtifactRef": {
        "additionalProperties": false,
        "properties": {
          "bytes": {
            "minimum": 0,
            "title": "Bytes",
            "type": "integer"
          },
          "media_type": {
            "maxLength": 100,
            "minLength": 1,
            "title": "Media Type",
            "type": "string"
          },
          "path": {
            "maxLength": 240,
            "minLength": 1,
            "title": "Path",
            "type": "string"
          },
          "role": {
            "maxLength": 80,
            "minLength": 1,
