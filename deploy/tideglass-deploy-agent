#!/usr/bin/env bash
# Pull-based production deployer for the public GitHub repository.
#
# The production laptop deliberately is not a GitHub Actions self-hosted runner. This
# agent only deploys the current main commit after GitHub reports that quality.yml
# completed successfully for that exact SHA.

set -Eeuo pipefail

REPOSITORY="${TIDEGLASS_GITHUB_REPOSITORY:-NishantParajuli/Reading-Wiki}"
REPOSITORY_URL="${TIDEGLASS_REPOSITORY_URL:-https://github.com/${REPOSITORY}.git}"
WORKFLOW_FILE="${TIDEGLASS_WORKFLOW_FILE:-quality.yml}"
BRANCH="${TIDEGLASS_DEPLOY_BRANCH:-main}"
DEPLOY_ROOT="${TIDEGLASS_DEPLOY_ROOT:-${HOME}/.local/share/tideglass-deploy}"
CHECKOUT_DIR="${TIDEGLASS_CHECKOUT_DIR:-${DEPLOY_ROOT}/repository}"
ROLLBACK_CHECKOUT_DIR="${TIDEGLASS_ROLLBACK_CHECKOUT_DIR:-${DEPLOY_ROOT}/rollback-repository}"
STATE_FILE="${TIDEGLASS_STATE_FILE:-${DEPLOY_ROOT}/last-deployed-sha}"
FAILED_STATE_FILE="${TIDEGLASS_FAILED_STATE_FILE:-${DEPLOY_ROOT}/failed-deployment-sha}"
ENV_FILE="${TIDEGLASS_ENV_FILE:-${HOME}/wiki/.env}"
COMPOSE_PROJECT="${TIDEGLASS_COMPOSE_PROJECT:-wiki}"
HEALTH_URL="${TIDEGLASS_HEALTH_URL:-http://127.0.0.1:8001/health}"
WEB_CONTAINER="${TIDEGLASS_WEB_CONTAINER:-novelwiki-web}"
WEB_IMAGE="${TIDEGLASS_WEB_IMAGE:-wiki-web:latest}"
ROLLBACK_IMAGE="${TIDEGLASS_ROLLBACK_IMAGE:-wiki-web:rollback}"
DRY_RUN="${TIDEGLASS_DRY_RUN:-0}"
HEALTH_ATTEMPTS="${TIDEGLASS_HEALTH_ATTEMPTS:-30}"
ROLLBACK_HEALTH_ATTEMPTS="${TIDEGLASS_ROLLBACK_HEALTH_ATTEMPTS:-15}"
HEALTH_RETRY_SECONDS="${TIDEGLASS_HEALTH_RETRY_SECONDS:-2}"

log() {
  printf '%s %s\n' "$(date --iso-8601=seconds)" "$*"
}

fail() {
  log "ERROR: $*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || fail "required command is unavailable: $1"
}

require_command curl
require_command docker
require_command flock
require_command git
require_command python3

record_failed_deployment() {
  local failed_tmp="${FAILED_STATE_FILE}.tmp"
  printf '%s\n' "${candidate_sha}" > "${failed_tmp}"
  mv "${failed_tmp}" "${FAILED_STATE_FILE}"
}

prepare_checkout() {
  local checkout_dir="$1"
  local revision="$2"

  if [[ ! -d "${checkout_dir}/.git" ]]; then
    log "creating isolated checkout at ${checkout_dir}"
    git clone --filter=blob:none --no-checkout "${REPOSITORY_URL}" "${checkout_dir}"
  fi

  git -C "${checkout_dir}" remote set-url origin "${REPOSITORY_URL}"
  git -C "${checkout_dir}" fetch --force --prune --depth=1 origin "${revision}"
  # These checkouts belong exclusively to the deploy agent; force removes artifacts
  # from a previous Docker build without touching the developer checkout in ~/wiki.
  git -C "${checkout_dir}" -c advice.detachedHead=false checkout --detach --force "${revision}"
  git -C "${checkout_dir}" clean -ffd
  # Older releases used a relative .env path. Keep rollback compatible with them while
  # newer releases use the absolute TIDEGLASS_ENV_FILE override.
  ln -sfn "${ENV_FILE}" "${checkout_dir}/.env"
}

wait_for_health() {
  local attempts="$1"
  local phase="$2"
  local attempt

  for ((attempt = 1; attempt <= attempts; attempt++)); do
    if curl --fail --silent --show-error --max-time 5 "${HEALTH_URL}" >/dev/null; then
      return 0
    fi
    log "${phase} health check ${attempt}/${attempts} failed; retrying"
    if ((attempt < attempts)); then
      sleep "${HEALTH_RETRY_SECONDS}"
    fi
  done
  return 1
}

rollback_deployment() {
  local reason="$1"

  log "${reason}"
  record_failed_deployment
  if [[ "${rollback_ready:-0}" != "1" ]]; then
    fail "deployment failed and no verified rollback release was available"
  fi

  log "rolling back to ${ROLLBACK_IMAGE} with release ${deployed_sha}"
  if ! docker tag "${ROLLBACK_IMAGE}" "${WEB_IMAGE}"; then
    fail "deployment failed and the rollback image could not be retagged"
  fi
  if ! "${rollback_compose[@]}" up -d --no-deps --force-recreate --no-build web; then
    fail "deployment failed and Compose could not recreate the previous web release"
  fi
  if wait_for_health "${ROLLBACK_HEALTH_ATTEMPTS}" "rollback"; then
    fail "deployment failed; the previous web release was restored successfully"
  fi
  fail "deployment and automatic rollback both failed health checks"
}

mkdir -p "${DEPLOY_ROOT}"
exec 9>"${DEPLOY_ROOT}/deploy.lock"
if ! flock -n 9; then
  log "another deployment check is already running"
  exit 0
fi

api_url="https://api.github.com/repos/${REPOSITORY}/actions/workflows/${WORKFLOW_FILE}/runs?branch=${BRANCH}&event=push&status=success&per_page=1"
run_json="$({
  curl --fail --silent --show-error --location \
    --retry 3 --connect-timeout 10 --max-time 30 \
    --header 'Accept: application/vnd.github+json' \
    --header 'X-GitHub-Api-Version: 2022-11-28' \
    --header 'User-Agent: tideglass-deploy-agent' \
    "${api_url}"
} || fail "could not read successful workflow runs from GitHub")"

mapfile -t run_details < <(
  printf '%s' "${run_json}" | python3 -c '
import json
import sys

runs = json.load(sys.stdin).get("workflow_runs", [])
if runs:
    print(runs[0].get("head_sha", ""))
    print(runs[0].get("html_url", ""))
'
)

candidate_sha="${run_details[0]:-}"
run_url="${run_details[1]:-}"
[[ "${candidate_sha}" =~ ^[0-9a-f]{40}$ ]] || fail "GitHub returned no valid successful commit SHA"

remote_sha="$(git ls-remote "${REPOSITORY_URL}" "refs/heads/${BRANCH}" | awk 'NR == 1 {print $1}')"
[[ "${remote_sha}" =~ ^[0-9a-f]{40}$ ]] || fail "could not resolve origin/${BRANCH}"

if [[ "${candidate_sha}" != "${remote_sha}" ]]; then
  log "origin/${BRANCH} is ${remote_sha}, but its successful CI run is not available yet"
  exit 0
fi

deployed_sha=""
if [[ -f "${STATE_FILE}" ]]; then
  deployed_sha="$(tr -d '[:space:]' < "${STATE_FILE}")"
fi
if [[ "${candidate_sha}" == "${deployed_sha}" ]]; then
  log "${candidate_sha} is already deployed"
  exit 0
fi

failed_sha=""
if [[ -f "${FAILED_STATE_FILE}" ]]; then
  failed_sha="$(tr -d '[:space:]' < "${FAILED_STATE_FILE}")"
fi
if [[ "${candidate_sha}" == "${failed_sha}" ]]; then
  log "${candidate_sha} previously failed deployment; refusing an automatic retry"
  log "remove ${FAILED_STATE_FILE} and start tideglass-deploy.service to retry manually"
  exit 0
fi

log "deployment candidate ${candidate_sha} passed CI (${run_url})"
if [[ "${DRY_RUN}" == "1" ]]; then
  log "dry run complete; no repository or Docker state was changed"
  exit 0
fi

[[ -r "${ENV_FILE}" ]] || fail "production env file is not readable: ${ENV_FILE}"

prepare_checkout "${CHECKOUT_DIR}" "${candidate_sha}"

export TIDEGLASS_ENV_FILE="${ENV_FILE}"
compose=(
  docker compose
  --project-name "${COMPOSE_PROJECT}"
  --project-directory "${CHECKOUT_DIR}"
  --env-file "${ENV_FILE}"
  --file "${CHECKOUT_DIR}/docker-compose.yml"
)

"${compose[@]}" config --quiet

previous_image="$(docker inspect --format '{{.Image}}' "${WEB_CONTAINER}" 2>/dev/null || true)"
rollback_ready=0
rollback_compose=()
if [[ -n "${previous_image}" ]]; then
  [[ "${deployed_sha}" =~ ^[0-9a-f]{40}$ ]] || fail "running web container exists but the deployed revision is unknown"
  prepare_checkout "${ROLLBACK_CHECKOUT_DIR}" "${deployed_sha}"
  rollback_compose=(
    docker compose
    --project-name "${COMPOSE_PROJECT}"
    --project-directory "${ROLLBACK_CHECKOUT_DIR}"
    --env-file "${ENV_FILE}"
    --file "${ROLLBACK_CHECKOUT_DIR}/docker-compose.yml"
  )
  "${rollback_compose[@]}" config --quiet
  docker tag "${previous_image}" "${ROLLBACK_IMAGE}"
  log "saved current web image ${previous_image} as ${ROLLBACK_IMAGE}"
  rollback_ready=1
fi

log "building web image for ${candidate_sha}"
"${compose[@]}" build --build-arg "SOURCE_COMMIT=${candidate_sha}" web

log "replacing only the web service"
if ! "${compose[@]}" up -d --no-deps web; then
  rollback_deployment "new deployment failed during docker compose up"
fi

if ! wait_for_health "${HEALTH_ATTEMPTS}" "deployment"; then
  rollback_deployment "new deployment failed its health check"
fi

running_revision="$(docker inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "${WEB_CONTAINER}" 2>/dev/null || true)"
if [[ "${running_revision}" != "${candidate_sha}" ]]; then
  rollback_deployment "healthy container revision '${running_revision}' does not match ${candidate_sha}"
fi

state_tmp="${STATE_FILE}.tmp"
printf '%s\n' "${candidate_sha}" > "${state_tmp}"
mv "${state_tmp}" "${STATE_FILE}"
rm -f "${FAILED_STATE_FILE}"
log "deployment complete: ${candidate_sha}"
